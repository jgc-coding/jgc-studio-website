---
// Hero-Resonance-Animation per Briefing 7.2.1
// 3 konzentrische Wellen, Quellwasser-Blau low opacity,
// zentraler Kupfer-Punkt. ~320px Desktop, ~200px Mobile.
interface Props {
  class?: string;
  size?: number;
}
const { class: className = '', size = 320 } = Astro.props;
---

<div
  class={`resonance-svg pointer-events-none select-none ${className}`}
  style={`width: ${size}px; height: ${size}px;`}
  aria-hidden="true"
>
  <svg viewBox="0 0 200 200" width="100%" height="100%" fill="none">
    <!-- Soft pergament veil so waves stay legible over photo -->
    <defs>
      <radialGradient id="veil" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FEFCF7" stop-opacity="0.30" />
        <stop offset="55%" stop-color="#FEFCF7" stop-opacity="0.12" />
        <stop offset="100%" stop-color="#FEFCF7" stop-opacity="0" />
      </radialGradient>
    </defs>
    <circle cx="100" cy="100" r="95" fill="url(#veil)" />

    <!-- Three concentric organic waves -->
    <g stroke="#86A89A" fill="none" stroke-width="1.5">
      <!-- slight irregularity via path with subtle bezier wobble -->
      <path class="wave wave-1"
        d="M100 30
           C 138 30 170 62 170 100
           C 170 138 138 171 100 170
           C 62 170 30 138 30 100
           C 30 62 62 30 100 30 Z" />
      <path class="wave wave-2"
        d="M100 28
           C 139 30 172 60 170 100
           C 171 139 139 172 100 172
           C 61 171 28 140 30 99
           C 29 60 60 29 100 28 Z" />
      <path class="wave wave-3"
        d="M100 32
           C 137 31 169 64 168 100
           C 169 137 137 170 100 168
           C 63 169 32 137 32 100
           C 31 63 63 32 100 32 Z" />
    </g>

    <!-- Center: copper voice point -->
    <circle cx="100" cy="100" r="6.5" fill="#3A574A" opacity="0.85" />
    <circle cx="100" cy="100" r="3" fill="#3A574A" />
  </svg>
</div>
