---
interface Props {
  eyebrow: string;
  number: string;
  title: string;
  price: string;
  duration: string;
  outcome: string;
  deliverables: string[];
  cta: string;
  highlighted?: boolean;
}
const {
  eyebrow, number, title, price, duration, outcome, deliverables, cta,
  highlighted = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article
  class:list={[
    'relative h-full flex flex-col bg-cream',
    'border transition-all duration-360 ease-out-strong',
    highlighted ? 'border-ink p-9 md:p-12 lg:p-14' : 'border-linen p-7 md:p-9',
    'hover:border-ink hover:shadow-[0_24px_48px_-28px_oklch(0.27_0.04_248/0.22)]',
  ]}
  style="border-radius: 4px;"
>
  {highlighted && (
    <div class="absolute -top-[1px] left-9 -translate-y-1/2 inline-flex items-center bg-cream px-3.5 py-1.5 font-serif italic text-[0.92rem] text-terracotta border border-linen" style="border-radius: 2px;">
      Häufigster Einstieg
    </div>
  )}

  <!-- Header: Numeral links, Eyebrow rechts -->
  <div class="flex items-baseline justify-between mb-8 pb-7 border-b border-linen">
    <p class={`numeral ${highlighted ? 'text-[clamp(4rem,5.5vw,5.75rem)]' : 'text-[clamp(3rem,4vw,4.25rem)]'}`}>{number}</p>
    <p class="font-sans text-eyebrow uppercase font-medium text-right" style="color: var(--color-ink); opacity: 0.55; letter-spacing: 0.22em;">{eyebrow}</p>
  </div>

  <h3
    class:list={[
      'font-serif text-ink mb-5',
      highlighted
        ? 'text-[clamp(1.85rem,2.4vw + 0.5rem,2.4rem)] leading-[1.05]'
        : 'text-[clamp(1.55rem,1.9vw + 0.4rem,1.95rem)] leading-[1.1]',
    ]}
  >
    {title}
  </h3>

  <div class="flex items-baseline gap-3 mb-2">
    <span
      class:list={[
        'font-serif text-ink',
        highlighted ? 'text-[2.3rem]' : 'text-[1.85rem]',
      ]}
    >
      {price}
    </span>
  </div>
  <p class="font-serif italic text-[0.98rem] text-ink/60 mb-7 pb-7 border-b border-linen">
    {duration}
  </p>

  <div class="mb-7">
    <p class="font-sans text-[0.72rem] uppercase tracking-[0.22em] text-ink/55 font-medium mb-3">
      Was danach gelöst ist
    </p>
    <p class={`font-serif text-charcoal leading-[1.55] ${highlighted ? 'text-[1.125rem]' : 'text-[1.0625rem]'}`}>
      {outcome}
    </p>
  </div>

  <div class="mb-9 flex-grow">
    <p class="font-sans text-[0.72rem] uppercase tracking-[0.22em] text-ink/55 font-medium mb-4">
      Was du in die Hand bekommst
    </p>
    <ul class="space-y-3">
      {deliverables.map((d) => (
        <li class="flex gap-3 items-start font-sans text-[0.96rem] text-charcoal leading-[1.55]">
          <span class="block flex-shrink-0 mt-[0.65rem] w-2.5 h-px bg-terracotta"></span>
          <span>{d}</span>
        </li>
      ))}
    </ul>
  </div>

  <a href={`${base}#kontakt`} class="btn-primary mt-auto w-full justify-center !text-[0.9rem]">
    {cta}
    <span class="btn-icon">
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 8 L13 8" />
        <path d="M8.5 3.5 L13 8 L8.5 12.5" />
      </svg>
    </span>
  </a>
</article>
