---
interface Props {
  eyebrow: string;
  number: string;
  title: string;
  price: string;
  duration: string;
  outcome: string;
  deliverables: string[];
  cta: string;
  highlighted?: boolean;
}
const {
  eyebrow, number, title, price, duration, outcome, deliverables, cta,
  highlighted = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article
  class:list={[
    'relative h-full flex flex-col p-8 md:p-10 transition-all duration-400 bg-cream',
    'border',
    highlighted ? 'border-ink shadow-card-hover' : 'border-linen',
    'hover:border-ink',
  ]}
  style="border-radius: 2px;"
>
  {highlighted && (
    <div class="absolute -top-[1px] left-8 -translate-y-1/2 inline-flex items-center bg-cream px-3 py-1.5 font-serif italic text-[0.85rem] text-terracotta border border-linen" style="border-radius: 2px;">
      Häufigster Einstieg
    </div>
  )}

  <!-- Editorial Header: große Italic-Nummer + Eyebrow -->
  <div class="flex items-start justify-between mb-7 pb-7 border-b border-linen">
    <p class="numeral text-[clamp(3rem,4vw,4.25rem)]">{number}</p>
    <p class="eyebrow text-right" style="color: var(--color-ink); opacity: 0.55;">{eyebrow}</p>
  </div>

  <h3 class="font-serif text-[clamp(1.5rem,1.8vw + 0.5rem,1.95rem)] leading-[1.1] text-ink mb-5" style="font-variation-settings: 'opsz' 144; font-weight: 400;">
    {title}
  </h3>

  <div class="flex items-baseline gap-3 mb-2">
    <span class="font-serif text-[1.95rem] text-ink" style="font-variation-settings: 'opsz' 144; font-weight: 400;">
      {price}
    </span>
  </div>
  <p class="font-serif italic text-[0.95rem] text-ink/60 mb-7 pb-7 border-b border-linen">
    {duration}
  </p>

  <div class="mb-7">
    <p class="font-sans text-[0.72rem] uppercase tracking-[0.20em] text-ink/55 font-medium mb-3">
      Was danach gelöst ist
    </p>
    <p class="font-serif text-[1.05rem] text-charcoal leading-[1.55]" style="font-variation-settings: 'opsz' 144; font-weight: 400;">
      {outcome}
    </p>
  </div>

  <div class="mb-9 flex-grow">
    <p class="font-sans text-[0.72rem] uppercase tracking-[0.20em] text-ink/55 font-medium mb-4">
      Was du in die Hand bekommst
    </p>
    <ul class="space-y-2.5">
      {deliverables.map((d) => (
        <li class="flex gap-3 items-start font-sans text-[0.95rem] text-charcoal leading-[1.55]">
          <span class="block flex-shrink-0 mt-[0.6rem] w-2.5 h-px bg-terracotta"></span>
          <span>{d}</span>
        </li>
      ))}
    </ul>
  </div>

  <a href={`${base}#kontakt`} class="btn-primary mt-auto w-full">
    {cta}
    <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 8 L13 8" />
      <path d="M8.5 3.5 L13 8 L8.5 12.5" />
    </svg>
  </a>
</article>
