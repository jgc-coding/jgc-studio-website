---
// Sehr blasses Resonanz-Symbol als Hintergrund-Präsenz (Briefing 7.0)
// Einmaliger Auftritt am Seitenrand zwischen Stimmen und Für-wen.
interface Props {
  side?: 'left' | 'right';
  vertical?: 'top' | 'bottom';
}
const { side = 'left', vertical = 'top' } = Astro.props;
---

<div
  class="absolute pointer-events-none select-none -z-0 hidden md:block"
  style={`
    ${side === 'left' ? 'left: -160px;' : 'right: -160px;'}
    ${vertical === 'top' ? 'top: -80px;' : 'bottom: -80px;'}
    width: 460px;
    height: 460px;
    opacity: 0.04;
  `}
  aria-hidden="true"
>
  <svg viewBox="0 0 200 200" width="100%" height="100%" fill="none" stroke="#86A89A" stroke-width="1.2">
    <circle cx="100" cy="100" r="32" />
    <circle cx="100" cy="100" r="58" />
    <circle cx="100" cy="100" r="84" />
    <circle cx="100" cy="100" r="6" fill="#86A89A" />
  </svg>
</div>
