---
import AngebotKarte from './AngebotKarte.astro';
---

<!-- V06: Asymmetric Bento — mittlere Karte größer (col-span-6), äußere kleiner (col-span-3) -->
<section id="angebote" class="section bg-cream">
  <div class="container-wide">

    <div class="text-center max-w-2xl mx-auto mb-20 md:mb-24 reveal">
      <p class="section-marker mb-5">Wege</p>
      <p class="eyebrow eyebrow-kupfer mb-5">Drei Wege ineinander</p>
      <h2 class="font-serif text-section text-ink">
        Vom ersten Befund<br />
        <em class="italic" style="color: var(--color-terracotta);">bis zum laufenden Verstärker.</em>
      </h2>
      <p class="mt-5 font-sans text-[1.05rem] text-charcoal/75 leading-relaxed">
        Du steigst dort ein, wo du gerade stehst. Jedes Angebot funktioniert für sich, und gemeinsam ergeben sie eine Linie.
      </p>
    </div>

    <!-- Asymmetric Grid: 3 / 6 / 3 cols on lg+ -->
    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-12 gap-7 lg:gap-8 items-stretch max-w-7xl mx-auto">

      <div class="md:col-span-6 lg:col-span-3 md:order-1 lg:order-1">
        <AngebotKarte
          number="01"
          eyebrow="Schritt 1, Klarheit"
          title="KI-Praxis-Check"
          price="600 €"
          duration="2 Stunden Gespräch + schriftlicher Report"
          outcome="Du weißt konkret, wo KI in deiner Praxis Zeit zurückgibt, wo deine aktuellen Tools EU-AI-Act- und DSGVO-tauglich sind und wo nicht, und welche drei bis fünf Schritte den größten Hebel haben."
          deliverables={[
            'Befund-Gespräch von 90 Minuten',
            'Schriftlicher Audit-Report (PDF, ca. 8 bis 12 Seiten)',
            'Drei bis fünf priorisierte Quick Wins mit konkreten Tool- und Prozess-Empfehlungen',
            'Bewertung deiner Tool-Landschaft auf DSGVO und EU AI Act',
          ]}
          cta="Audit anfragen"
        />
      </div>

      <div class="md:col-span-12 lg:col-span-6 md:order-3 lg:order-2">
        <AngebotKarte
          number="02"
          eyebrow="Schritt 2, Aufbau"
          title="KI-Implementierung für deine Praxis"
          price="6.500 €"
          duration="6 bis 8 Wochen"
          outcome="Du hast ein KI-System, das in deiner Sprache schreibt, deine Sitzungen nachbereitet und dein Klienten-Follow-up automatisch anstößt. Inklusive der Schulung, die deine EU-AI-Act-Pflicht erfüllt."
          deliverables={[
            'Voice-Profil aus deinen Texten, Podcasts und Sitzungs-Aufnahmen',
            'Content-System für LinkedIn, Newsletter und Reels-Skripte',
            'DSGVO-konforme Sitzungs-Transkription mit automatischer Zusammenfassung',
            'Automatisches Klienten-Follow-up nach Sitzungen',
            'Lead-Funnel mit personalisiertem Onboarding',
            'Drei Schulungs-Sessions zur eigenständigen Bedienung',
            'Integrierte EU-AI-Act-Schulung',
          ]}
          cta="Projekt anfragen"
          highlighted
        />
      </div>

      <div class="md:col-span-6 lg:col-span-3 md:order-2 lg:order-3">
        <AngebotKarte
          number="03"
          eyebrow="Schritt 3, Tiefe"
          title="Methodik-Assistent und KI-Verstärker"
          price="14.000 €"
          duration="10 bis 12 Wochen"
          outcome="Dein Buch, deine Methode, dein Programm sind in einem Assistenten verfügbar, der nach dir klingt: für deine Klienten, für deine Inhalte, für dein Team. Deine Wirkung wächst, ohne dass du dafür mehr Stunden gibst."
          deliverables={[
            'Methodik-Assistent auf Basis deiner Bücher, Modelle und Texte (technische Grundlage RAG)',
            'Content-Stimme zur authentischen Reproduktion deiner Sprachfarbe (technische Grundlage ElevenLabs)',
            'Webseiten-Embedding für Klienten-Interaktion',
            'Integration in den Praxis-Workflow aus Schritt 2',
            'Intensive Begleitung über drei Monate',
            'Quartals-Review nach Abschluss',
          ]}
          cta="Projekt anfragen"
        />
      </div>
    </div>
  </div>
</section>
