---
const pillars = [
  {
    num: 'I',
    title: 'Coach-Hintergrund',
    text: 'Ausgebildeter Mentaltrainer und Meditationskursleiter, in Ausbildung als Fitnesstrainer. Ich kenne die innere Welt deiner Arbeit aus eigener Anschauung.',
  },
  {
    num: 'II',
    title: 'Wirtschaftsingenieur',
    text: 'Master in Wirtschaftsingenieurwesen. Mein Beruf ist es, zwischen verschiedenen Welten zu übersetzen: Technik, Wirtschaft, Mensch. Ich denke in Abläufen und Prozessen, ohne den Menschen darin aus den Augen zu verlieren.',
  },
  {
    num: 'III',
    title: 'TÜV-zertifizierter KI-Experte',
    text: 'TÜV-Zertifikat Angewandte KI-Transformation. Eigene KI-Anwendungen entwickelt und in Praxen anderer integriert. KI ist nicht mein Hobby, sondern meine tägliche Arbeit, mit der Begeisterung von jemandem, der weiß, was diese Werkzeuge können und wo ihre Grenzen liegen.',
  },
];
---

<section id="wer" class="section bg-cream">
  <div class="container-wide">

    <div class="text-center max-w-2xl mx-auto mb-20 md:mb-24 reveal">
      <p class="section-marker mb-5">Wer mit dir arbeitet</p>
      <p class="eyebrow eyebrow-kupfer mb-5">Wer mit dir arbeitet</p>
      <h2 class="font-serif text-section text-ink">
        Drei Welten,<br />
        <em class="italic" style="color: var(--color-terracotta);">ein Blick.</em>
      </h2>
      <p class="mt-5 font-sans text-[1.05rem] text-charcoal/75 leading-relaxed">
        Ich verstehe die innere Welt deiner Arbeit, das Denken in Abläufen dahinter und die KI-Werkzeuge, die beides verbinden.
      </p>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-3 gap-x-8 lg:gap-x-16 gap-y-14 items-start max-w-5xl mx-auto">
      {pillars.map((p) => (
        <div class="md:border-l md:border-linen md:pl-7 lg:pl-10 md:first:border-l-0 md:first:pl-0">
          <p class="numeral text-[clamp(4.5rem,7vw,6.5rem)] mb-8">{p.num}</p>
          <h3 class="font-serif text-[1.55rem] md:text-[1.7rem] text-ink mb-4 leading-[1.15]">
            {p.title}
          </h3>
          <p class="font-sans text-[1rem] text-charcoal leading-[1.65]">
            {p.text}
          </p>
        </div>
      ))}
    </div>

    <p class="mt-20 text-center font-serif italic text-[1.05rem] text-ink/65 reveal">
      Standort Freiburg im Breisgau. Arbeite im DACH-Raum, persönlich und remote.
    </p>
  </div>
</section>
