---
const punkte = [
  'KI ersetzt keine echte Beziehung. Begegnung bleibt menschlich.',
  'Klienten wissen, wo KI eingesetzt wird. Transparenz ist Standard.',
  'Ich baue für dich, nicht für die Masse. Jedes Setup wird auf deine Methode und deinen Stil zugeschnitten.',
  'Sensible Daten werden geschützt. EU-Hosting, Auftragsverarbeitungsverträge, lokale Modelle bei Bedarf.',
  'Du bleibst Entscheider. KI macht Vorschläge, du wählst aus. Nichts geht raus, ohne dass du es gesehen hast.',
  'Deine Stimme und deine Methode bleiben erkennbar. KI verstärkt, sie ersetzt nicht.',
];
---

<section id="grundwerte" class="relative w-full" style="background-color: var(--bg-salbei-medium);">
  <div class="container-wide py-32 md:py-40 lg:py-44">

    <div class="text-center max-w-2xl mx-auto mb-20 md:mb-24 reveal">
      <p class="section-marker mb-5">Haltung</p>
      <p class="eyebrow eyebrow-tinte mb-5">Haltung vor Technik</p>
      <h2 class="font-serif text-section text-ink">
        Meine Grundwerte,<br />
        <em class="italic" style="color: var(--color-terracotta);">wenn ich mit KI arbeite.</em>
      </h2>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-x-14 lg:gap-x-20 gap-y-10 max-w-5xl mx-auto">
      {punkte.map((punkt, i) => (
        <div class="flex gap-6 items-start">
          <span class="numeral text-[2.75rem] md:text-[3rem] flex-shrink-0 leading-[0.85]" style="color: var(--color-ink); opacity: 0.45; min-width: 3.25rem;">
            {String(i + 1).padStart(2, '0')}
          </span>
          <p class="font-serif text-[1.1rem] md:text-[1.15rem] text-ink leading-[1.5] pt-1.5">
            {punkt}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
