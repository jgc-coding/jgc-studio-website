---
const stimmen = [
  {
    quote: 'Was vorher zwei Abende pro Woche fraß, läuft jetzt im Hintergrund. Und das Beste: meine Klienten merken keinen Unterschied — außer, dass ich präsenter bin.',
    name: 'Pilotkundin (Platzhalter)',
    role: 'Mental-Coach, München',
  },
  {
    quote: 'Ich war skeptisch, ob ein KI-Setup wirklich „nach mir" klingen kann. Tut es. Das war der Punkt, an dem aus Werkzeug Verstärker wurde.',
    name: 'Pilotkunde (Platzhalter)',
    role: 'Trainer für Führungskräfte, Wien',
  },
  {
    quote: 'Der Audit allein war den Preis schon wert. Drei konkrete Schritte, mit denen ich sofort weiterkam — kein Tech-Sprech, einfach klare Empfehlungen.',
    name: 'Pilotkundin (Platzhalter)',
    role: 'Mentorin, Hamburg',
  },
];
---

<section class="section bg-cream">
  <div class="container-wide">

    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-20 reveal">
      <p class="section-marker mb-5">vi.  Stimmen</p>
      <p class="eyebrow eyebrow-kupfer mb-5">Stimmen aus der Praxis</p>
      <h2 class="font-serif text-section text-ink" style="font-variation-settings: 'opsz' 144;">
        Was Kunden<br /><em class="italic" style="font-weight: 350;">über die Arbeit sagen.</em>
      </h2>
      <p class="mt-4 font-serif italic text-[0.95rem] text-ink/55">
        — Pilotkunden-Zitate folgen. Die hier gezeigten Karten sind Platzhalter.
      </p>
    </div>

    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-3 gap-x-10 lg:gap-x-14 gap-y-12 max-w-6xl mx-auto">
      {stimmen.map((s) => (
        <figure class="relative">
          <!-- Großes editorial Anführungszeichen -->
          <span class="font-serif italic block text-[5rem] leading-[0.7] text-terracotta/70 mb-2" aria-hidden="true">
            "
          </span>
          <blockquote class="pull-quote text-[1.1rem] md:text-[1.15rem] mb-7">
            {s.quote}
          </blockquote>
          <figcaption class="pt-5 border-t border-linen">
            <p class="font-sans text-[0.98rem] text-ink font-medium">{s.name}</p>
            <p class="font-serif italic text-[0.92rem] text-ink/55 mt-0.5">{s.role}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
