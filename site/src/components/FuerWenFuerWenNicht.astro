---
const fuer = [
  'Du eine eigene Methode oder ein eigenes Programm hast, das in deiner Arbeit trägt.',
  'Du regelmäßig Inhalte veröffentlichst — Newsletter, Podcast, Posts — und merkst, dass dich das Tempo zermürbt.',
  'Du KI nutzen willst, ohne dass dein Schreiben generisch wird.',
  'Du tech-skeptisch bist und genau deshalb jemanden brauchst, der die Werkzeuge für dich baut, statt dir Tutorials zu schicken.',
  'Du in einer Praxis mit Klienten arbeitest und dafür Rechtssicherheit brauchst, die wirklich greift.',
];
const nicht = [
  'Du gerade erst startest und deine Methode noch nicht steht. Hier hilft kein Tool, sondern erst einmal Klarheit über dein Angebot.',
  'Du eine Marketing-Maschine suchst, die dich ersetzt. Das baue ich nicht.',
  'Du KI als Beziehungsersatz für deine Klienten einsetzen willst.',
  'Du erwartest, dass der Aufbau ohne deine Mitarbeit funktioniert. Voice-Profile, Methodik-Assistenten und Praxis-Workflows brauchen dich als Quelle.',
];
---

<section class="section bg-cream">
  <div class="container-wide">

    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-20 reveal">
      <p class="section-marker mb-5">vii.  Ehrlich gesagt</p>
      <p class="eyebrow eyebrow-kupfer mb-5">Ehrlich gesagt</p>
      <h2 class="font-serif text-section text-ink" style="font-variation-settings: 'opsz' 144;">
        Lass uns schauen,<br /><em class="italic" style="font-weight: 350;">ob das passt.</em>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 max-w-6xl mx-auto reveal">

      <!-- Passt für dich -->
      <div class="md:border-r md:border-linen md:pr-10 lg:pr-14 pb-12 md:pb-0">
        <p class="font-serif italic text-[1.5rem] md:text-[1.65rem] text-ink mb-9" style="font-weight: 400;">
          Passt für dich, wenn …
        </p>
        <ul class="space-y-5">
          {fuer.map((line) => (
            <li class="flex gap-4 items-start font-sans text-[1.025rem] text-charcoal leading-[1.6]">
              <span class="block flex-shrink-0 mt-[0.55rem] w-3 h-3 border border-ink/65" style="border-radius: 1px;" aria-hidden="true"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Passt nicht -->
      <div class="md:pl-10 lg:pl-14 pt-12 md:pt-0 border-t md:border-t-0 border-linen">
        <p class="font-serif italic text-[1.5rem] md:text-[1.65rem] text-ink/65 mb-9" style="font-weight: 400;">
          Passt nicht, wenn …
        </p>
        <ul class="space-y-5">
          {nicht.map((line) => (
            <li class="flex gap-4 items-start font-sans text-[1.025rem] text-charcoal/75 leading-[1.6]">
              <span class="block flex-shrink-0 mt-[0.85rem] w-3 h-px bg-ink/40" aria-hidden="true"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
