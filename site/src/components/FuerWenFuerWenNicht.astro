---
// Sektion 7.8 — Für wen das gemacht ist, und für wen nicht
const fuer = [
  'Du eine eigene Methode oder ein eigenes Programm hast, das in deiner Arbeit trägt.',
  'Du regelmäßig Inhalte veröffentlichst — Newsletter, Podcast, Posts — und merkst, dass dich das Tempo zermürbt.',
  'Du KI nutzen willst, ohne dass dein Schreiben generisch wird.',
  'Du tech-skeptisch bist und genau deshalb jemanden brauchst, der die Werkzeuge für dich baut, statt dir Tutorials zu schicken.',
  'Du in einer Praxis mit Klienten arbeitest und dafür Rechtssicherheit brauchst, die wirklich greift.',
];
const nicht = [
  'Du gerade erst startest und deine Methode noch nicht steht. Hier hilft kein Tool, sondern erst einmal Klarheit über dein Angebot.',
  'Du eine Marketing-Maschine suchst, die dich ersetzt. Das baue ich nicht.',
  'Du KI als Beziehungsersatz für deine Klienten einsetzen willst.',
  'Du erwartest, dass der Aufbau ohne deine Mitarbeit funktioniert. Voice-Profile, Methodik-Assistenten und Praxis-Workflows brauchen dich als Quelle.',
];
---

<section class="section bg-pergament">
  <div class="container-wide">

    <div class="text-center max-w-2xl mx-auto mb-14 md:mb-20">
      <p class="eyebrow eyebrow-kupfer mb-5">Ehrlich gesagt</p>
      <h2 class="font-serif text-section text-tinte">
        Lass uns schauen, ob das passt.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-7 max-w-6xl mx-auto">

      <!-- Passt für dich -->
      <div
        class="p-8 md:p-10 lg:p-12 rounded-[6px]"
        style="background-color: #E3ECDD; border: 1px solid rgba(182, 207, 176, 0.55);"
      >
        <p class="font-serif italic text-[1.4rem] md:text-[1.5rem] text-tinte mb-7">
          Passt für dich, wenn …
        </p>
        <ul class="space-y-4">
          {fuer.map((line) => (
            <li class="flex gap-3.5 items-start font-sans text-[1.0125rem] text-anthrazit leading-[1.6]">
              <svg class="flex-shrink-0 mt-[0.4rem]" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="#86A89A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2.5 7.5 L5.5 10.5 L11.5 3.5" />
              </svg>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Passt nicht -->
      <div
        class="p-8 md:p-10 lg:p-12 rounded-[6px]"
        style="background-color: #ECEBDB; border: 1px solid rgba(210, 211, 187, 0.7);"
      >
        <p class="font-serif italic text-[1.4rem] md:text-[1.5rem] text-tinte mb-7">
          Passt nicht, wenn …
        </p>
        <ul class="space-y-4">
          {nicht.map((line) => (
            <li class="flex gap-3.5 items-start font-sans text-[1.0125rem] text-anthrazit leading-[1.6]">
              <svg class="flex-shrink-0 mt-[0.4rem]" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="#A89580" stroke-width="1.8" stroke-linecap="round">
                <path d="M3 7 L11 7" />
              </svg>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
