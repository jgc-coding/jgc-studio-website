---
/**
 * LogoResonanz — animiertes Hintergrund-Motiv aus dem Markenlogo
 * Übernommen aus der Komponentenvorlage (logo-resonanz-komponente.html).
 *
 * Verwendung als dezenter Hintergrund-Akzent. Eltern-Container braucht
 * position: relative + overflow: hidden, sonst ragt das Motiv hervor.
 *
 * Props:
 *   side       'right' | 'left'   (default 'right')  — welche Seite angeschnitten
 *   vertical   'bottom' | 'top'   (default 'bottom') — oben oder unten
 *   size       Pixelmaß           (default 360)
 *   opacity    0-1                (default 0.08)     — dezent, leicht sichtbar
 *   inset      Pixel              (default -110)     — wie weit es über die Kante hinausragt
 *   instanceId String             (default 'av-clip-1') — eindeutig falls mehrfach genutzt
 *
 * Reduziert Bewegung bei prefers-reduced-motion automatisch.
 */
interface Props {
  side?: 'left' | 'right';
  vertical?: 'top' | 'bottom';
  size?: number;
  opacity?: number;
  inset?: number;
  instanceId?: string;
}
const {
  side = 'right',
  vertical = 'bottom',
  size = 360,
  opacity = 0.08,
  inset = -110,
  instanceId = 'av-clip-1',
} = Astro.props;

const styleVars = `
  --logo-resonanz-size: ${size}px;
  --logo-resonanz-opacity: ${opacity};
  ${side === 'right' ? `right: ${inset}px;` : `left: ${inset}px;`}
  ${vertical === 'bottom' ? `bottom: ${inset}px;` : `top: ${inset}px;`}
`;
---

<div class="logo-resonanz logo-resonanz--ecke" style={styleVars} aria-hidden="true">
  <svg viewBox="-153.5 -119.5 520 520" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <clipPath id={instanceId} clipPathUnits="userSpaceOnUse">
        <circle class="av-clip-circle" cx="106.5" cy="140.5" r="113" />
      </clipPath>
    </defs>
    <g class="av-waves">
      <circle class="av-wave-1" cx="106.5" cy="140.5" r="112" fill="none" stroke="#6FA3B5" stroke-width="1.5" vector-effect="non-scaling-stroke" />
      <circle class="av-wave-2" cx="106.5" cy="140.5" r="112" fill="none" stroke="#6FA3B5" stroke-width="1.5" vector-effect="non-scaling-stroke" />
      <circle class="av-wave-3" cx="106.5" cy="140.5" r="112" fill="none" stroke="#6FA3B5" stroke-width="1.5" vector-effect="non-scaling-stroke" />
    </g>
    <g class="av-logo-scale"><g class="av-logo-rotate"><g clip-path={`url(#${instanceId})`}>
      <g transform="translate(1.1570838,-4.1655018)">
        <g transform="rotate(-2.5714334,105.29579,144.62009)">
