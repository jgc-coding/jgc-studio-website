          <path fill="#232a43" transform="rotate(175.53323,105.50789,149.95675)" d="m 170.72916,65.025522 c 0,0 0.45985,-0.01082 0,0 -6.06181,0.142616 -20.3013,0.663805 -37.19763,3.921989 -0.70685,0.136304 -1.41689,0.277083 -2.12985,0.422471 -9.43612,1.92423 -21.94283,5.076677 -34.718172,10.556313 -10.954495,4.698634 -22.180221,11.138802 -31.85327,20.024928 -9.246377,8.494167 -16.722488,18.907267 -21.330783,31.481987 -1.750843,4.67224 -2.796694,9.03904 -3.228605,13.11579 -0.460262,4.34435 -0.214884,8.28564 0.560421,11.81995 0.103402,0.47137 0.215995,0.9344 0.33722,1.38909 0.852058,3.19589 2.152301,6.06833 3.772022,8.6148 1.903712,2.99295 4.230019,5.50803 6.768202,7.59617 5.160678,4.24565 11.321631,6.83927 17.355215,8.32833 6.025992,1.48719 12.316528,1.97129 18.147814,1.72725 1.577347,-0.0869 3.117638,-0.21287 4.621836,-0.37148 6.780925,-0.71502 12.9259,-2.3156 18.48978,-4.8213 7.64487,-3.44287 12.08696,-7.60085 13.82023,-9.32451 0.067,-0.0667 0,0 0,0 a 1.6875707,1.6875707 90 0 0 -2.1781,-2.57826 c 0,0 0.0721,-0.0509 0,0 -1.86341,1.3148 -6.40752,4.6003 -13.5802,6.91501 -5.17744,1.67082 -10.851035,2.52514 -16.902717,2.42235 -1.351295,-0.023 -2.730099,-0.10407 -4.136444,-0.24113 -5.117336,-0.4319 -10.352281,-1.70177 -15.064202,-3.68832 -4.762692,-2.00795 -8.865799,-4.68944 -11.946154,-7.90403 -1.495762,-1.56094 -2.755666,-3.25125 -3.760523,-5.07883 -0.851392,-1.54847 -1.551641,-3.25306 -2.050889,-5.14395 -0.07175,-0.27176 -0.140036,-0.54983 -0.204378,-0.83439 -0.47661,-2.10788 -0.751425,-4.63583 -0.577684,-7.67051 0.164034,-2.8651 0.729625,-6.20754 1.921881,-10.08391 3.391501,-10.65644 9.141705,-19.88395 16.782181,-27.86338 8.047219,-8.404211 17.791949,-15.001619 27.839219,-20.135677 11.69717,-5.97714 23.37932,-9.768115 32.5272,-12.130921 0.68297,-0.176404 1.36367,-0.348404 2.04183,-0.516108 16.0232,-3.962432 30.15957,-5.339429 36.08895,-5.818952 0.45043,-0.03643 0,0 0,0 a 2.068165,2.068165 90 0 0 -0.2144,-4.13077 z" />
        </g>
      </g>
    </g></g></g>
  </svg>
</div>

<style>
  .logo-resonanz {
    --cycle: 20s;
    width: var(--logo-resonanz-size, 360px);
    height: var(--logo-resonanz-size, 360px);
    opacity: var(--logo-resonanz-opacity, 0.08);
    pointer-events: none;
  }
  .logo-resonanz svg { width: 100%; height: 100%; display: block; overflow: visible; }

  .logo-resonanz--ecke {
    position: absolute;
    z-index: 0;
  }

  .logo-resonanz .av-clip-circle,
  .logo-resonanz .av-logo-rotate,
  .logo-resonanz .av-logo-scale,
  .logo-resonanz .av-wave-1,
  .logo-resonanz .av-wave-2,
  .logo-resonanz .av-wave-3 {
    transform-box: view-box;
    transform-origin: 106.5px 140.5px;
  }
  .logo-resonanz .av-clip-circle { animation: av-reveal var(--cycle) linear infinite; }
  .logo-resonanz .av-logo-rotate { animation: av-rotate var(--cycle) linear infinite; }
  .logo-resonanz .av-logo-scale  { animation: av-shrink var(--cycle) linear infinite; }
  .logo-resonanz .av-wave-1 { animation: av-ripple1 var(--cycle) ease-out infinite; }
  .logo-resonanz .av-wave-2 { animation: av-ripple2 var(--cycle) ease-out infinite; }
  .logo-resonanz .av-wave-3 { animation: av-ripple3 var(--cycle) ease-out infinite; }

  @keyframes av-reveal {
    0%   { transform: scale(0); animation-timing-function: cubic-bezier(0.42,0,0.58,1); }
    3%   { transform: scale(0); animation-timing-function: cubic-bezier(0.42,0,0.58,1); }
    30%  { transform: scale(1); animation-timing-function: cubic-bezier(0.42,0,0.58,1); }
    100% { transform: scale(1); }
  }
  @keyframes av-rotate {
    0%     { transform: rotate(-90deg);    animation-timing-function: linear; }
    25.43% { transform: rotate(-28.203deg); animation-timing-function: linear; }
    73.77% { transform: rotate(46.939deg);  animation-timing-function: linear; }
    100%   { transform: rotate(89.411deg); }
  }
  @keyframes av-shrink {
    0%     { transform: scale(0.007);  animation-timing-function: cubic-bezier(0.42,0,0.58,1); }
    29.31% { transform: scale(0.9445); animation-timing-function: cubic-bezier(0.42,0,0.58,1); }
    64.49% { transform: scale(0.9555); animation-timing-function: cubic-bezier(0.42,0,0.58,1); }
    100%   { transform: scale(0); }
  }
  @keyframes av-ripple1 {
    0%     { transform: scale(1);     opacity: 0; }
    30%    { transform: scale(1);     opacity: 0; }
    31.08% { transform: scale(1.078); opacity: 0.55; }
    48%    { transform: scale(2.304); opacity: 0; }
    100%   { transform: scale(1);     opacity: 0; }
  }
  @keyframes av-ripple2 {
    0%     { transform: scale(1);     opacity: 0; }
    38%    { transform: scale(1);     opacity: 0; }
    39.08% { transform: scale(1.078); opacity: 0.5; }
    56%    { transform: scale(2.304); opacity: 0; }
    100%   { transform: scale(1);     opacity: 0; }
  }
  @keyframes av-ripple3 {
    0%     { transform: scale(1);     opacity: 0; }
    46%    { transform: scale(1);     opacity: 0; }
    47.08% { transform: scale(1.078); opacity: 0.45; }
    64%    { transform: scale(2.304); opacity: 0; }
    100%   { transform: scale(1);     opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-resonanz * { animation: none !important; }
    .logo-resonanz .av-clip-circle { transform: scale(1); }
    .logo-resonanz .av-waves { opacity: 0; }
  }
</style>
