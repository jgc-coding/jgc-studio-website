---
const heute = [
  'Sitzungsnotizen liegen verstreut in Notion, auf Zetteln, in Voice-Memos.',
  'Klienten-Follow-ups schiebst du auf den Abend, der nicht ruhig wird.',
  'Der Newsletter wartet seit drei Wochen auf den Sonntag, der nicht kommt.',
];
const verstaerker = [
  'Die Sitzungszusammenfassung steht, bevor du das Notizbuch zuklappst.',
  'Das Follow-up an deine Klientin geht heraus, in deiner Sprache.',
  'Der nächste Newsletter liegt im Entwurf, aus echten Themen deiner Woche.',
];
---

<section class="section bg-cream">
  <div class="container-wide">

    <div class="text-center max-w-2xl mx-auto mb-20 md:mb-24 reveal">
      <p class="section-marker mb-5">Vorher · Nachher</p>
      <p class="eyebrow eyebrow-kupfer mb-5">Deine Woche, zwei Versionen</p>
      <h2 class="font-serif text-section text-ink">
        Was sich verändert,<br />
        <em class="italic" style="color: var(--color-terracotta);">wenn KI deine Sprache spricht.</em>
      </h2>
    </div>

    <!-- Asymmetric: linke Spalte kleiner, rechte größer (visuelle Hierarchie zugunsten Nachher) -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-y-12 md:gap-x-12 lg:gap-x-20 max-w-6xl mx-auto reveal">

      <!-- Heute -->
      <div class="md:col-span-5 md:pt-4">
        <div class="flex items-baseline gap-4 mb-9">
          <span class="numeral text-[3rem]" style="color: var(--color-ink); opacity: 0.40;">A</span>
          <p class="font-serif italic text-[1.45rem] text-ink/70" style="font-weight: 400;">Heute</p>
        </div>
        <ul class="space-y-5">
          {heute.map((line) => (
            <li class="font-sans text-[1.0125rem] text-charcoal/85 leading-[1.65] flex gap-4">
              <span class="block flex-shrink-0 mt-[0.7rem] w-3 h-px bg-ink/30"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Verstärker (größer, im Fokus) -->
      <div class="md:col-span-7 md:border-l md:border-linen md:pl-12 lg:pl-20">
        <div class="flex items-baseline gap-4 mb-9">
          <span class="numeral text-[3.5rem]" style="color: var(--color-terracotta);">B</span>
          <p class="font-serif italic text-[1.65rem] text-ink" style="font-weight: 400;">Mit deinem KI-Verstärker</p>
        </div>
        <ul class="space-y-6">
          {verstaerker.map((line) => (
            <li class="font-serif text-[1.15rem] md:text-[1.2rem] text-ink leading-[1.55] flex gap-4">
              <span class="block flex-shrink-0 mt-[0.85rem] w-4 h-px bg-terracotta"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="mt-20 md:mt-24 text-center font-serif italic text-[1.1rem] md:text-[1.15rem] text-ink/70 max-w-2xl mx-auto leading-relaxed reveal">
      Du bekommst keine Tool-Liste und keinen Online-Kurs. Du bekommst eine Begleitung, in der wir gemeinsam herausarbeiten, wo KI in deiner Arbeit Substanz hat, und sie genau dort einbauen.
    </p>
  </div>
</section>
