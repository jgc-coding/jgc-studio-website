---
const heute = [
  'Sitzungsnotizen liegen verstreut in Notion, auf Zetteln, in Voice-Memos.',
  'Klienten-Follow-ups schiebst du auf den Abend, der nicht ruhig wird.',
  'Der Newsletter wartet seit drei Wochen auf den Sonntag, der nicht kommt.',
];
const verstaerker = [
  'Die Sitzungszusammenfassung steht, bevor du das Notizbuch zuklappst.',
  'Das Follow-up an deine Klientin geht heraus, in deiner Sprache.',
  'Der nächste Newsletter liegt im Entwurf, aus echten Themen deiner Woche.',
];
---

<section class="section bg-cream">
  <div class="container-wide">

    <div class="text-center max-w-2xl mx-auto mb-16 md:mb-20 reveal">
      <p class="section-marker mb-5">iii.  Vorher · Nachher</p>
      <p class="eyebrow eyebrow-kupfer mb-5">Deine Woche, zwei Versionen</p>
      <h2 class="font-serif text-section text-ink" style="font-variation-settings: 'opsz' 144;">
        Was sich verändert,<br /><em class="italic" style="font-weight: 350;">wenn KI deine Sprache spricht.</em>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 max-w-5xl mx-auto reveal">

      <!-- Heute — left column -->
      <div class="md:border-r md:border-linen md:pr-10 lg:pr-14 pb-12 md:pb-0">
        <div class="flex items-baseline gap-3 mb-9">
          <span class="numeral text-[2.5rem]" style="color: var(--color-ink); opacity: 0.5;">A</span>
          <p class="font-serif italic text-[1.4rem] text-ink/80" style="font-weight: 400;">Heute</p>
        </div>
        <ul class="space-y-6">
          {heute.map((line) => (
            <li class="font-sans text-[1.025rem] text-charcoal leading-[1.65] flex gap-4">
              <span class="block flex-shrink-0 mt-[0.65rem] w-3 h-px bg-ink/35"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Mit KI-Verstärker — right column -->
      <div class="md:pl-10 lg:pl-14 pt-12 md:pt-0 border-t md:border-t-0 border-linen">
        <div class="flex items-baseline gap-3 mb-9">
          <span class="numeral text-[2.5rem]" style="color: var(--color-terracotta);">B</span>
          <p class="font-serif italic text-[1.4rem] text-ink" style="font-weight: 400;">Mit deinem KI-Verstärker</p>
        </div>
        <ul class="space-y-6">
          {verstaerker.map((line) => (
            <li class="font-sans text-[1.025rem] text-charcoal leading-[1.65] flex gap-4">
              <span class="block flex-shrink-0 mt-[0.65rem] w-3 h-px bg-terracotta"></span>
              <span>{line}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="mt-16 md:mt-20 text-center font-serif italic text-[1.05rem] md:text-[1.1rem] text-ink/65 max-w-2xl mx-auto leading-relaxed reveal">
      Du bekommst keine Tool-Liste und keinen Online-Kurs. Du bekommst eine Begleitung, in der wir gemeinsam herausarbeiten, wo KI in deiner Arbeit Substanz hat — und sie genau dort einbauen.
    </p>
  </div>
</section>
