---
const base = import.meta.env.BASE_URL;
---

<!-- V04: Editorial centered hero with overlapping headline + floating side-cards -->
<section class="relative w-full bg-pergament pt-6 md:pt-10 lg:pt-14 pb-32 md:pb-40 lg:pb-44 overflow-clip">
  <div class="container-wide relative">

    <!-- 1) Centered hero image (contained, not full-bleed) -->
    <div class="relative mx-auto max-w-[640px] md:max-w-[720px] lg:max-w-[760px]">
      <div class="relative aspect-[4/5] overflow-hidden rounded-[4px] bg-holzsand/30 hero-photo-shadow">
        <img
          src={`${base}images/hero-placeholder.png`}
          alt="Ruhiger Arbeitsplatz mit Holzschreibtisch, Pflanzen und Tageslicht"
          class="absolute inset-0 w-full h-full object-cover"
          width="1500"
          height="1875"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <!-- Very subtle bottom vignette for legibility of CTA -->
        <div
          class="absolute inset-x-0 bottom-0 h-44 pointer-events-none"
          style="background: linear-gradient(to top, rgba(254,252,247,0.55) 0%, rgba(254,252,247,0) 100%);"
          aria-hidden="true"
        ></div>
      </div>

      <!-- 2) Headline OVERLAPS the top of the image (sits over the upper portion) -->
      <h1
        class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-2 md:-translate-y-4
               w-[110%] md:w-[120%] lg:w-[125%] max-w-[1100px]
               text-center px-2
               font-serif font-medium text-tinte
               leading-[0.95] tracking-[-0.025em]
               text-[clamp(2.6rem,9vw,7.5rem)]
               drop-shadow-[0_1px_0_rgba(254,252,247,0.6)]"
        style="text-shadow: 0 1px 2px rgba(254, 252, 247, 0.45);"
      >
        MEHR RAUM FÜR<br />
        <em class="italic font-medium" style="font-variation-settings: 'opsz' 144, 'SOFT' 100;">DAS WESENTLICHE.</em>
      </h1>

      <!-- 3) Sub-text below headline, still over upper-middle of image -->
      <div class="absolute top-[clamp(8.5rem,21vw,17rem)] left-1/2 -translate-x-1/2 w-[88%] md:w-[78%] text-center">
        <p class="font-sans text-[0.96rem] md:text-[1.0625rem] text-tinte/85 leading-relaxed max-w-md mx-auto">
          KI, die deine Handschrift trägt. Für Coaches, Trainer und Mentoren.
        </p>
      </div>

      <!-- 4) Primary CTA — dark pill, centered over the lower-middle of the image -->
      <div class="absolute left-1/2 -translate-x-1/2 bottom-[28%] md:bottom-[26%]">
        <a href={`${base}#kontakt`} class="hero-pill-cta">
          AUDIT ANFRAGEN
        </a>
      </div>
    </div>

    <!-- 5) Two floating cards sticking out at the bottom-left and bottom-right of the image -->
    <div class="floating-cards-wrap absolute inset-x-0 bottom-0 pointer-events-none">
      <div class="container-wide relative h-0">

        <!-- LEFT card — Erstgespräch -->
        <a
          href={`${base}#kontakt`}
          class="floating-card group absolute pointer-events-auto"
          style="left: 0; bottom: 90px;"
        >
          <div class="floating-card-image floating-card-image-warm" aria-hidden="true">
            <!-- Subtle abstract: warm holzsand block with calendar/clock icon -->
            <svg viewBox="0 0 100 100" class="w-12 h-12 text-tinte/55" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="50" cy="50" r="32" />
              <path d="M50 30 L50 50 L65 58" />
            </svg>
          </div>
          <div class="floating-card-body">
            <span class="floating-card-label">60 Minuten<br />Erstgespräch</span>
            <span class="floating-card-arrow group-hover:bg-kupfer group-hover:text-pergament transition-colors duration-300">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 10 L10 4" />
                <path d="M5 4 L10 4 L10 9" />
              </svg>
            </span>
          </div>
        </a>

        <!-- RIGHT card — Angebote -->
        <a
          href={`${base}#angebote`}
          class="floating-card group absolute pointer-events-auto"
          style="right: 0; bottom: 90px;"
        >
          <div class="floating-card-image floating-card-image-sage" aria-hidden="true">
            <!-- Subtle abstract: salbei block with three-step path icon -->
            <svg viewBox="0 0 100 100" class="w-14 h-14 text-tinte/55" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="22" cy="50" r="5" />
              <circle cx="50" cy="50" r="5" />
              <circle cx="78" cy="50" r="5" />
              <path d="M28 50 L44 50" opacity="0.5" />
              <path d="M55 50 L72 50" opacity="0.5" />
            </svg>
          </div>
          <div class="floating-card-body">
            <span class="floating-card-label">Drei Wege<br />einsteigen</span>
            <span class="floating-card-arrow group-hover:bg-kupfer group-hover:text-pergament transition-colors duration-300">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 10 L10 4" />
                <path d="M5 4 L10 4 L10 9" />
              </svg>
            </span>
          </div>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .hero-photo-shadow {
    box-shadow: 0 24px 60px -30px rgba(31, 42, 68, 0.22);
  }

  /* Primary dark pill CTA (Tina-style) */
  :global(.hero-pill-cta) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 2rem;
    background-color: var(--color-tinte);
    color: var(--color-pergament);
    font-family: 'Inter Variable', Inter, ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.86rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-radius: 999px;
    transition: background-color 220ms ease, transform 300ms ease, box-shadow 300ms ease;
    box-shadow: 0 6px 20px -8px rgba(31, 42, 68, 0.30);
  }
  :global(.hero-pill-cta:hover) {
    background-color: var(--color-kupfer);
    transform: translateY(-1px);
    box-shadow: 0 10px 28px -10px rgba(201, 123, 63, 0.45);
  }

  /* Floating side cards */
  :global(.floating-card) {
    display: block;
    width: clamp(180px, 22vw, 260px);
    background-color: var(--color-pergament);
    border: 1px solid var(--color-holzsand);
    border-radius: 6px;
    box-shadow: 0 14px 32px -16px rgba(31, 42, 68, 0.20);
    transition: transform 350ms cubic-bezier(0.32, 0.72, 0, 1),
                box-shadow 350ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  :global(.floating-card:hover) {
    transform: translateY(-4px);
    box-shadow: 0 22px 44px -20px rgba(31, 42, 68, 0.28);
  }

  :global(.floating-card-image) {
    height: 110px;
    border-radius: 5px 5px 0 0;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  :global(.floating-card-image-warm) {
    background: linear-gradient(135deg, #EFE6D2 0%, #E7DDC4 100%);
  }
  :global(.floating-card-image-sage) {
    background: linear-gradient(135deg, #DCE4D4 0%, #C9D7C1 100%);
  }

  :global(.floating-card-body) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 0.95rem 0.95rem 1.05rem;
    border-top: 1px solid var(--color-holzsand);
  }
  :global(.floating-card-label) {
    font-family: 'Inter Variable', Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1.25;
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-tinte);
  }
  :global(.floating-card-arrow) {
    flex: 0 0 auto;
    width: 30px; height: 30px;
    display: inline-flex; align-items: center; justify-content: center;
    background-color: var(--color-holzsand);
    color: var(--color-tinte);
    border-radius: 4px;
  }

  /* Mobile: cards become inline below image instead of floating */
  @media (max-width: 767px) {
    .floating-cards-wrap { position: static; }
    .floating-cards-wrap > .container-wide { height: auto; padding: 0; margin-top: 2.5rem; }
    .floating-cards-wrap .floating-card {
      position: static !important;
      width: 100% !important;
      margin: 0 auto 1rem auto;
      max-width: 320px;
    }
    .floating-cards-wrap .container-wide {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
