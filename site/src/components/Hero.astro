---
const base = import.meta.env.BASE_URL;
---

<!-- V05 Hero: Magazin-Cover-Anmutung
     Linke Spalte: nur Typografie, viel Whitespace, große italic Display-Headline
     Rechte Spalte: Hochformat-Foto, ein Detail vom Logo-Sigel als Wasserzeichen
-->
<section class="relative w-full bg-cream pt-8 md:pt-16 lg:pt-20 pb-16 md:pb-24 lg:pb-28">
  <div class="container-wide">

    <!-- Editorial Header-Zeile -->
    <div class="flex items-end justify-between mb-12 md:mb-20 pb-5 border-b border-linen">
      <p class="font-sans uppercase text-eyebrow font-medium text-ink/70" style="letter-spacing: 0.22em;">
        Sales-Page · Vol. 1
      </p>
      <p class="hidden md:block font-serif italic text-marine text-[0.95rem]">
        — Freiburg im Breisgau, 2026
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- LEFT — Editorial Typografie -->
      <div class="lg:col-span-7 lg:pr-6 xl:pr-12">

        <p class="section-marker mb-7 reveal">i.  Ankunft</p>

        <h1 class="font-serif text-hero text-ink reveal" style="font-variation-settings: 'opsz' 144;">
          Mehr Raum<br />
          für das <em class="italic" style="color: var(--color-terracotta); font-weight: 350;">Wesentliche.</em>
        </h1>

        <p class="mt-9 md:mt-10 font-serif italic text-sub text-ink max-w-xl reveal" style="font-variation-settings: 'opsz' 144; font-weight: 400;">
          KI, die deine Handschrift trägt. Für Coaches, Trainer und Mentoren.
        </p>

        <p class="mt-5 font-sans text-[1.05rem] text-charcoal/75 max-w-lg leading-[1.65] reveal">
          Ich verstärke, was dich auszeichnet — DSGVO-konform und maßgeschneidert.
        </p>

        <div class="mt-10 md:mt-12 flex flex-col sm:flex-row gap-3.5 sm:items-center reveal">
          <a href={`${base}#kontakt`} class="btn-primary">
            Audit anfragen
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8 L13 8" />
              <path d="M8.5 3.5 L13 8 L8.5 12.5" />
            </svg>
          </a>
          <a href={`${base}#angebote`} class="btn-secondary">
            Angebote ansehen
          </a>
        </div>

        <!-- Editorial trust-line: dünn unter den Buttons -->
        <div class="mt-14 md:mt-16 pt-5 border-t border-linen flex flex-wrap gap-x-8 gap-y-2 items-center font-serif italic text-[0.92rem] text-ink/65">
          <span>EU-gehostet</span>
          <span class="text-linen">·</span>
          <span>TÜV-zertifiziert</span>
          <span class="text-linen">·</span>
          <span>EU-AI-Act-konform</span>
        </div>
      </div>

      <!-- RIGHT — Editorial Foto -->
      <div class="lg:col-span-5 relative reveal">
        <div class="relative aspect-[4/5] overflow-hidden bg-linen/40">
          <img
            src={`${base}images/hero-placeholder.png`}
            alt="Ruhiger Arbeitsplatz mit Holzschreibtisch, Pflanzen und Tageslicht"
            class="absolute inset-0 w-full h-full object-cover"
            width="1200"
            height="1500"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>

        <!-- Editorial Bildunterschrift -->
        <p class="mt-4 flex items-baseline gap-3 font-serif italic text-[0.88rem] text-ink/55">
          <span class="font-sans not-italic text-[0.7rem] uppercase tracking-[0.22em] text-ink/45 translate-y-[-1px]">Fig. 01</span>
          Mein Arbeitsplatz, Freiburg im Breisgau.
        </p>
      </div>
    </div>
  </div>
</section>
