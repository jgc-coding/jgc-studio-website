---
const base = import.meta.env.BASE_URL;
---

<!-- V06 Hero: Editorial Split — massive Typo links, ruhiges Bild rechts, viel Atem -->
<section class="relative w-full bg-cream pt-12 md:pt-20 lg:pt-24 pb-20 md:pb-28 lg:pb-36 overflow-clip">
  <div class="container-wide">

    <!-- Magazin-Header oben -->
    <div class="flex items-baseline justify-between mb-14 md:mb-24 pb-5 border-b border-linen reveal">
      <p class="font-sans uppercase text-eyebrow font-medium text-ink/70" style="letter-spacing: 0.22em;">
        Sales-Page Nº 01
      </p>
      <p class="hidden md:block font-serif italic text-marine text-[1rem]">
        Freiburg im Breisgau, 2026
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-10 gap-y-14 lg:gap-y-0 items-start">

      <!-- LEFT — Editorial Massive Typo (Editorial Split per Taste-Skill) -->
      <div class="lg:col-span-7 xl:col-span-7">

        <p class="section-marker mb-7 reveal">Ankunft</p>

        <h1 class="font-serif text-hero text-ink reveal">
          Mehr Raum<br />
          für das <em class="italic" style="color: var(--color-terracotta);">Wesentliche.</em>
        </h1>

        <p class="mt-10 md:mt-12 font-serif italic text-sub text-ink/90 max-w-xl reveal">
          KI, die deine Handschrift trägt. Für Coaches, Trainer und Mentoren.
        </p>

        <p class="mt-5 font-sans text-[1.05rem] text-charcoal/75 max-w-md leading-[1.65] reveal">
          Ich verstärke, was dich auszeichnet: DSGVO-konform und maßgeschneidert.
        </p>

        <div class="mt-12 flex flex-col sm:flex-row gap-3.5 sm:items-center reveal">
          <a href={`${base}#kontakt`} class="btn-primary">
            Audit anfragen
            <span class="btn-icon">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 8 L13 8" />
                <path d="M8.5 3.5 L13 8 L8.5 12.5" />
              </svg>
            </span>
          </a>
          <a href={`${base}#angebote`} class="btn-secondary">
            Angebote ansehen
          </a>
        </div>

        <div class="mt-16 pt-5 border-t border-linen flex flex-wrap gap-x-7 gap-y-2 items-center font-serif italic text-[0.95rem] text-ink/65 reveal">
          <span>EU-gehostet</span>
          <span class="text-linen">·</span>
          <span>TÜV-zertifiziert</span>
          <span class="text-linen">·</span>
          <span>EU-AI-Act-konform</span>
        </div>
      </div>

      <!-- RIGHT — Foto in editorial Treatment (kleiner, ruhiger, dünnem Rahmen) -->
      <div class="lg:col-span-5 xl:col-span-5 lg:pt-8 reveal">
        <div class="relative">
          <div class="relative aspect-[4/5] overflow-hidden bg-linen/40 rounded-[2px]" style="box-shadow: 0 32px 64px -36px oklch(0.27 0.04 248 / 0.22);">
            <img
              src={`${base}images/hero-placeholder.png`}
              alt="Ruhiger Arbeitsplatz mit Holzschreibtisch, Pflanzen und Tageslicht"
              class="absolute inset-0 w-full h-full object-cover"
              width="1200"
              height="1500"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>

          <!-- Editorial Bildunterschrift mit Fig.-Label -->
          <div class="mt-5 flex items-baseline gap-3">
            <span class="font-sans text-[0.7rem] uppercase tracking-[0.24em] text-ink/45">Fig. 01</span>
            <span class="font-serif italic text-[0.95rem] text-ink/65">
              Mein Arbeitsplatz, Freiburg.
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
