---
import LogoResonanz from './LogoResonanz.astro';
const base = import.meta.env.BASE_URL;
---

<!-- Full-bleed cinematic hero: edge-to-edge, no rounding, flush to nav above and next section below -->
<section class="hero-cinema relative w-full overflow-hidden bg-tinte">

  <!-- Background image -->
  <img
    src={`${base}images/hero-placeholder.png`}
    alt="Ruhiger Arbeitsplatz mit Holzschreibtisch, Pflanzen und Tageslicht"
    class="absolute inset-0 w-full h-full object-cover"
    width="2400"
    height="1500"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />

  <!-- Brand gradient — Tinte-Tiefblau, leicht fade-out nach rechts -->
  <div class="absolute inset-0 hero-gradient-desktop hidden md:block" aria-hidden="true"></div>
  <div class="absolute inset-0 hero-gradient-mobile md:hidden" aria-hidden="true"></div>

  <!-- 1) Atmosphaerische Logo-Resonanz top-right, sehr leise im dunklen Cinema-Bereich
       (Crescendo-Stufe 1/5: nur fuer Augen, die hinschauen) -->
  <div class="absolute inset-0 z-[1] pointer-events-none hidden md:block" aria-hidden="true">
    <LogoResonanz
      side="right"
      vertical="top"
      size={620}
      opacity={0.035}
      insetX={-180}
      insetY={-200}
      instanceId="hero-resonanz"
    />
  </div>

  <!-- Content layer — constrained to container-wide so text aligns with rest of site -->
  <div class="relative z-10 container-wide">
    <div class="grid grid-cols-1 lg:grid-cols-12 min-h-[640px] sm:min-h-[700px] md:min-h-[760px] lg:min-h-[82vh] xl:min-h-[86vh]">

      <!-- LEFT — Text -->
      <div class="lg:col-span-7 xl:col-span-6 flex flex-col justify-center py-20 md:py-24 lg:py-28 lg:pr-12">

        <!-- Eyebrow marker -->
        <div class="flex items-center gap-3 mb-7 md:mb-10">
          <span class="block h-px w-9 bg-kupfer/90"></span>
          <span class="eyebrow" style="color: #E8A572; letter-spacing: 0.18em;">Freiburg im Breisgau</span>
        </div>

        <!-- Headline -->
        <h1 class="font-serif text-hero" style="color: #FEFCF7;">
          Mehr Raum für<br class="hidden sm:block" />
          das <em
            class="italic font-medium"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 100; color: #FEFCF7;"
          >Wesentliche</em>.
        </h1>

        <!-- Sub-Headline -->
        <p class="mt-7 md:mt-8 font-sans text-sub font-medium max-w-xl" style="color: rgba(254, 252, 247, 0.96);">
          KI, die deine Handschrift trägt. Für Coaches, Trainer und Mentoren.
        </p>

        <!-- Sub-Sub-Claim -->
        <p class="mt-3.5 font-sans text-[1.0625rem] max-w-xl leading-relaxed" style="color: rgba(254, 252, 247, 0.78);">
          Ich verstärke, was dich auszeichnet — DSGVO-konform und maßgeschneidert.
        </p>

        <!-- CTAs -->
        <div class="mt-9 md:mt-11 flex flex-col sm:flex-row gap-3.5 sm:items-center">
          <a href={`${base}#kontakt`} class="btn-primary">
            Audit anfragen
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8 L13 8" />
              <path d="M8.5 3.5 L13 8 L8.5 12.5" />
            </svg>
          </a>
          <a href={`${base}#angebote`} class="btn-secondary-on-dark">
            Angebote ansehen
          </a>
        </div>

        <!-- Trust hairline -->
        <div class="mt-12 md:mt-16 flex flex-wrap gap-x-7 gap-y-2 items-center text-[0.84rem] font-sans" style="color: rgba(254, 252, 247, 0.68);">
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-salbei"></span>
            EU-gehostet
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-kupfer"></span>
            TÜV-zertifiziert
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-quellwasser"></span>
            EU AI Act-konform
          </span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Desktop — gradient from left (dark, where text sits) to transparent right */
  .hero-gradient-desktop {
    background:
      linear-gradient(
        to right,
        rgba(31, 42, 68, 0.86) 0%,
        rgba(31, 42, 68, 0.78) 18%,
        rgba(31, 42, 68, 0.58) 38%,
        rgba(31, 42, 68, 0.30) 58%,
        rgba(31, 42, 68, 0.08) 78%,
        rgba(31, 42, 68, 0.00) 100%
      );
  }

  /* Mobile — gradient from bottom-up (text stacks bottom of image) */
  .hero-gradient-mobile {
    background:
      linear-gradient(
        to bottom,
        rgba(31, 42, 68, 0.30) 0%,
        rgba(31, 42, 68, 0.55) 35%,
        rgba(31, 42, 68, 0.82) 75%,
        rgba(31, 42, 68, 0.92) 100%
      );
  }

  /* Secondary button on dark hero — light outline + light text */
  :global(.btn-secondary-on-dark) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'Inter Variable', Inter, ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
    padding: 0.8125rem 1.5625rem;
    background-color: transparent;
    color: #FEFCF7;
    border: 1.5px solid rgba(254, 252, 247, 0.55);
    border-radius: 5px;
    font-size: 0.98rem;
    transition: background-color 220ms ease, border-color 220ms ease, color 180ms ease;
  }
  :global(.btn-secondary-on-dark:hover) {
    background-color: rgba(254, 252, 247, 0.12);
    border-color: #FEFCF7;
    color: #FEFCF7;
  }
</style>
