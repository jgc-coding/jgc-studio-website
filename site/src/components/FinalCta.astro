---
const base = import.meta.env.BASE_URL;
---

<section id="kontakt" class="relative w-full" style="background-color: var(--bg-salbei-final);">
  <div class="container-wide py-32 md:py-40 lg:py-48 relative">

    <div class="max-w-3xl mx-auto text-center reveal">

      <p class="section-marker mb-5">Schluss</p>
      <p class="eyebrow eyebrow-kupfer mb-7">Ein Gespräch</p>

      <h2 class="font-serif text-ink leading-[1.0] tracking-tight" style="font-size: clamp(2.75rem, 5.5vw, 4.5rem);">
        Lass uns<br />
        <em class="italic" style="color: var(--color-terracotta);">60 Minuten</em> reden.
      </h2>

      <p class="mt-10 font-serif italic text-[1.2rem] md:text-[1.3rem] text-ink/75 max-w-lg mx-auto leading-relaxed">
        Kostenfreies Erstgespräch. Kein Verkaufsgespräch, keine Verpflichtung.
      </p>

      <div class="mt-14 flex flex-col sm:flex-row items-center justify-center gap-5">
        <a href={`${base}#kontakt`} class="btn-primary !text-[0.95rem] !py-3.5 !pl-7">
          Audit anfragen
          <span class="btn-icon">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8 L13 8" />
              <path d="M8.5 3.5 L13 8 L8.5 12.5" />
            </svg>
          </span>
        </a>
        <a href={`${base}#angebote`} class="btn-tertiary text-[0.96rem]">
          oder Demo-Workflow ansehen
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
