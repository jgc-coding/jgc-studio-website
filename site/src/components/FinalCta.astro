---
const base = import.meta.env.BASE_URL;
---

<section id="kontakt" class="relative w-full" style="background-color: var(--bg-salbei-final);">
  <div class="container-wide py-28 md:py-36 lg:py-40 relative">

    <div class="max-w-3xl mx-auto text-center reveal">

      <p class="section-marker mb-5">x.  Schluss</p>
      <p class="eyebrow eyebrow-kupfer mb-7">Ein Gespräch</p>

      <h2 class="font-serif text-ink leading-[1.0] tracking-tight" style="font-variation-settings: 'opsz' 144; font-weight: 400; font-size: clamp(2.5rem, 5vw, 4rem);">
        Lass uns<br /><em class="italic" style="font-weight: 350; color: var(--color-terracotta);">60 Minuten</em> reden.
      </h2>

      <p class="mt-9 font-serif italic text-[1.15rem] md:text-[1.2rem] text-ink/75 max-w-lg mx-auto leading-relaxed" style="font-weight: 400;">
        Kostenfreies Erstgespräch. Kein Verkaufsgespräch, keine Verpflichtung.
      </p>

      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-5">
        <a href={`${base}#kontakt`} class="btn-primary !px-8 !py-4 !text-[0.98rem]">
          Audit anfragen
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 8 L13 8" />
            <path d="M8.5 3.5 L13 8 L8.5 12.5" />
          </svg>
        </a>
        <a href={`${base}#angebote`} class="btn-tertiary text-[0.95rem]">
          oder Demo-Workflow ansehen
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
