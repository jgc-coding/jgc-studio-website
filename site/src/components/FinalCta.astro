---
// Sektion 7.11 — Final-CTA
// Salbei-Block volle Breite, innere Box mit Kupfer-Rahmen.
// Kleines statisches Resonanz-Echo oben mittig.
const base = import.meta.env.BASE_URL;
---

<section id="kontakt" class="relative w-full" style="background-color: var(--bg-salbei-final);">
  <div class="container-wide py-24 md:py-32 lg:py-36">

    <div
      class="relative mx-auto bg-pergament rounded-[6px] px-7 md:px-12 lg:px-16 py-14 md:py-20"
      style="max-width: 760px; border: 1.5px solid rgba(58, 87, 74, 0.85); box-shadow: 0 2px 12px -4px rgba(44,62,54,0.08);"
    >

      <!-- Resonance echo -->
      <div class="absolute left-1/2 -translate-x-1/2 -top-9 md:-top-11">
        <div class="bg-pergament rounded-full p-2.5">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="#3A574A" stroke-width="1.3" opacity="0.55">
            <circle cx="32" cy="32" r="10" />
            <circle cx="32" cy="32" r="18" opacity="0.7" />
            <circle cx="32" cy="32" r="26" opacity="0.45" />
            <circle cx="32" cy="32" r="3.5" fill="#3A574A" opacity="1" stroke="none" />
          </svg>
        </div>
      </div>

      <div class="text-center">
        <h2 class="font-serif text-[clamp(1.8rem,2.5vw+0.5rem,2.65rem)] leading-[1.15] text-tinte">
          Lass uns 60 Minuten reden.
        </h2>
        <p class="mt-5 font-sans text-[1.0625rem] md:text-[1.125rem] text-anthrazit/75 leading-relaxed max-w-md mx-auto">
          Kostenfreies Erstgespräch. Kein Verkaufsgespräch, keine Verpflichtung.
        </p>

        <div class="mt-9 md:mt-10 flex flex-col items-center gap-5">
          <a href={`${base}#kontakt`} class="btn-primary !px-7 !py-3.5 !text-[1rem]">
            Audit anfragen
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8 L13 8" />
              <path d="M8.5 3.5 L13 8 L8.5 12.5" />
            </svg>
          </a>
          <a href={`${base}#angebote`} class="btn-tertiary text-[0.95rem]">
            oder Demo-Workflow ansehen
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Atemraum-Pause vor dem Footer -->
  <div class="h-20 bg-pergament" aria-hidden="true"></div>
</section>
