---
const base = import.meta.env.BASE_URL;
const links = [
  { label: 'Angebote', href: `${base}#angebote` },
  { label: 'Grundwerte', href: `${base}#grundwerte` },
  { label: 'Wer mit dir arbeitet', href: `${base}#wer` },
];
const homeHref = base;
const ctaHref = `${base}#kontakt`;
---

<header class="site-nav fixed inset-x-0 top-0 z-40">
  <div class="container-wide flex items-center justify-between h-[64px] md:h-[72px]">

    <!-- Wortmarke -->
    <a href={homeHref} class="flex items-baseline gap-2.5 group" aria-label="JGC Studio – zurück zum Anfang">
      <span class="font-serif text-ink text-[1.5rem] md:text-[1.6rem] font-normal tracking-tight leading-none">
        JGC Studio
      </span>
      <span class="hidden sm:inline font-serif italic text-marine text-[0.78rem] tracking-tight leading-none translate-y-[-1px]">
        — Freiburg
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-9" aria-label="Hauptnavigation">
      {links.map((l) => (
        <a
          href={l.href}
          class="font-sans text-[0.9rem] text-ink/80 hover:text-terracotta transition-colors duration-240"
        >
          {l.label}
        </a>
      ))}
      <a href={ctaHref} class="btn-primary text-[0.86rem] !py-2.5 !px-5">
        Audit anfragen
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden inline-flex flex-col items-end justify-center w-10 h-10 gap-[5px] -mr-1"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block h-[1.5px] w-6 bg-ink"></span>
      <span class="block h-[1.5px] w-4 bg-ink"></span>
      <span class="block h-[1.5px] w-6 bg-ink"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-linen bg-cream/98 backdrop-blur-md">
    <nav class="container-wide py-6 flex flex-col gap-1" aria-label="Mobilnavigation">
      {links.map((l) => (
        <a
          href={l.href}
          class="font-sans text-ink text-[1.05rem] py-3 border-b border-linen/60 last:border-b-0"
          data-mobile-link
        >
          {l.label}
        </a>
      ))}
      <a href={ctaHref} class="btn-primary mt-4 w-full" data-mobile-link>
        Audit anfragen
      </a>
    </nav>
  </div>
</header>

<div class="h-[64px] md:h-[72px]" aria-hidden="true" id="top"></div>

<script>
  const nav = document.querySelector('.site-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 8) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    const close = () => { menu.classList.add('hidden'); btn.setAttribute('aria-expanded', 'false'); };
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
    menu.querySelectorAll('[data-mobile-link]').forEach((a) => a.addEventListener('click', close));
  }
</script>
