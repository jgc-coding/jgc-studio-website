---
const base = import.meta.env.BASE_URL;
const links = [
  { label: 'Angebote', href: `${base}#angebote` },
  { label: 'Grundwerte', href: `${base}#grundwerte` },
  { label: 'Wer mit dir arbeitet', href: `${base}#wer` },
];
const homeHref = base;
const ctaHref = `${base}#kontakt`;
---

<header class="site-nav fixed inset-x-0 top-0 z-40">
  <div class="container-wide flex items-center justify-between h-[68px] md:h-[76px]">

    <a href={homeHref} class="flex items-baseline gap-2.5 group" aria-label="JGC Studio – zurück zum Anfang">
      <span class="font-serif text-ink text-[1.55rem] md:text-[1.7rem] font-normal tracking-tight leading-none">
        JGC Studio
      </span>
      <span class="hidden sm:inline font-serif italic text-marine text-[0.82rem] tracking-tight leading-none">
        Freiburg
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-9" aria-label="Hauptnavigation">
      {links.map((l) => (
        <a href={l.href} class="font-sans text-[0.92rem] text-ink/80 hover:text-terracotta transition-colors duration-240 ease-out-strong">
          {l.label}
        </a>
      ))}
      <a href={ctaHref} class="btn-primary !text-[0.88rem]">
        Audit anfragen
        <span class="btn-icon">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8 L13 8" />
            <path d="M8.5 3.5 L13 8 L8.5 12.5" />
          </svg>
        </span>
      </a>
    </nav>

    <button
      id="mobile-menu-btn"
      class="lg:hidden inline-flex flex-col items-end justify-center w-10 h-10 gap-[5px] -mr-1"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block h-[1.5px] w-6 bg-ink"></span>
      <span class="block h-[1.5px] w-4 bg-ink"></span>
      <span class="block h-[1.5px] w-6 bg-ink"></span>
    </button>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-linen bg-cream/98 backdrop-blur-md">
    <nav class="container-wide py-6 flex flex-col gap-1" aria-label="Mobilnavigation">
      {links.map((l) => (
        <a href={l.href} class="font-sans text-ink text-[1.05rem] py-3 border-b border-linen/60 last:border-b-0" data-mobile-link>
          {l.label}
        </a>
      ))}
      <a href={ctaHref} class="btn-primary mt-4 w-full justify-center" data-mobile-link>
        Audit anfragen
        <span class="btn-icon">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8 L13 8" />
            <path d="M8.5 3.5 L13 8 L8.5 12.5" />
          </svg>
        </span>
      </a>
    </nav>
  </div>
</header>

<div class="h-[68px] md:h-[76px]" aria-hidden="true" id="top"></div>

<script>
  const nav = document.querySelector('.site-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 8) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    const close = () => { menu.classList.add('hidden'); btn.setAttribute('aria-expanded', 'false'); };
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
    menu.querySelectorAll('[data-mobile-link]').forEach((a) => a.addEventListener('click', close));
  }
</script>
