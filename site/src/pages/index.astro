---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import KiIstWerkzeug from '../components/KiIstWerkzeug.astro';
import VorherNachher from '../components/VorherNachher.astro';
import DreiAngebote from '../components/DreiAngebote.astro';
import WerMitDirArbeitet from '../components/WerMitDirArbeitet.astro';
import Stimmen from '../components/Stimmen.astro';
import FuerWenFuerWenNicht from '../components/FuerWenFuerWenNicht.astro';
import Grundwerte from '../components/Grundwerte.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />

  <main id="main">
    <Hero />
    <KiIstWerkzeug />
    <VorherNachher />
    <DreiAngebote />
    <WerMitDirArbeitet />
    <Stimmen />
    <FuerWenFuerWenNicht />
    <Grundwerte />
    <Faq />
    <FinalCta />
  </main>

  <Footer />
</BaseLayout>

<!-- Phase 2: Ruhige Scroll-Reveals via IntersectionObserver
     Respektiert prefers-reduced-motion (alle reveals bleiben dann sichtbar). -->
<script>
  const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduce) {
    const targets = document.querySelectorAll('.reveal, .reveal-stagger');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );
    targets.forEach((t) => observer.observe(t));
  } else {
    // Reduced motion: alles sofort sichtbar
    document.querySelectorAll('.reveal, .reveal-stagger').forEach((t) => t.classList.add('is-visible'));
  }
</script>
