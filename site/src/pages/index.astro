---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import PersoenlicherIntro from '../components/PersoenlicherIntro.astro';
import KiIstWerkzeug from '../components/KiIstWerkzeug.astro';
import VorherNachher from '../components/VorherNachher.astro';
import BogenTrenner from '../components/BogenTrenner.astro';
import DreiAngebote from '../components/DreiAngebote.astro';
import WerMitDirArbeitet from '../components/WerMitDirArbeitet.astro';
import Stimmen from '../components/Stimmen.astro';
import HintergrundResonanz from '../components/HintergrundResonanz.astro';
import FuerWenFuerWenNicht from '../components/FuerWenFuerWenNicht.astro';
import Grundwerte from '../components/Grundwerte.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />

  <main id="main">

    <!-- 2. Hero (V04: zentriert, Floating Cards) -->
    <Hero />

    <!-- 2b. Persönliche Intro (V04: Tina-Stil, „Hi. Ich bin Gabriel.") -->
    <PersoenlicherIntro />

    <!-- 3. KI ist ein Werkzeug -->
    <KiIstWerkzeug />

    <!-- 4. Vorher-Nachher -->
    <VorherNachher />

    <!-- Bogen-Trenner #1 -->
    <BogenTrenner />

    <!-- 5. Drei Angebote -->
    <DreiAngebote />

    <!-- 6. Wer mit dir arbeitet -->
    <WerMitDirArbeitet />

    <!-- 7. Stimmen -->
    <Stimmen />

    <!-- Bogen-Trenner #2 -->
    <BogenTrenner />

    <!-- 8. Für wen / für wen nicht — with background resonance presence -->
    <div class="relative overflow-clip">
      <HintergrundResonanz side="left" vertical="top" />
      <FuerWenFuerWenNicht />
    </div>

    <!-- 9. Grundwerte -->
    <Grundwerte />

    <!-- 10. FAQ -->
    <Faq />

    <!-- 11. Final-CTA -->
    <FinalCta />
  </main>

  <!-- 12. Footer -->
  <Footer />
</BaseLayout>
