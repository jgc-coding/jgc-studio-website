---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import KiIstWerkzeug from '../components/KiIstWerkzeug.astro';
import VorherNachher from '../components/VorherNachher.astro';
import DreiAngebote from '../components/DreiAngebote.astro';
import WerMitDirArbeitet from '../components/WerMitDirArbeitet.astro';
import Stimmen from '../components/Stimmen.astro';
import FuerWenFuerWenNicht from '../components/FuerWenFuerWenNicht.astro';
import Grundwerte from '../components/Grundwerte.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />

  <main id="main">

    <!-- 2. Hero -->
    <Hero />

    <!-- 3. KI ist ein Werkzeug — receives hero photo overlap on lg+ -->
    <KiIstWerkzeug />

    <!-- 4. Vorher-Nachher -->
    <VorherNachher />

    <!-- 5. Drei Angebote -->
    <DreiAngebote />

    <!-- 6. Wer mit dir arbeitet -->
    <WerMitDirArbeitet />

    <!-- 7. Stimmen -->
    <Stimmen />

    <!-- 8. Für wen / für wen nicht -->
    <FuerWenFuerWenNicht />

    <!-- 9. Grundwerte -->
    <Grundwerte />

    <!-- 10. FAQ -->
    <Faq />

    <!-- 11. Final-CTA -->
    <FinalCta />
  </main>

  <!-- 12. Footer -->
  <Footer />
</BaseLayout>
